# Environment Variables Template
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

DB_HOST=db
DB_NAME=securecart
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING

# Optional — Cursor MCP (postgres): same DB_* credentials; host must reach Postgres from your OS.
# After `docker compose up`, 127.0.0.1:5432 is published by docker-compose for this lab.
# MCP_DATABASE_URL=postgresql://postgres:CHANGE_ME_TO_A_STRONG_PASSWORD@127.0.0.1:5432/securecart
#
# Optional — Cursor MCP (github): ${env:GITHUB_PERSONAL_ACCESS_TOKEN} in .cursor/mcp.json reads the
# process environment. If MCP does not see it, set this variable in Windows User env or your shell
# before starting Cursor (having it only in .env may not be enough).
# GITHUB_PERSONAL_ACCESS_TOKEN=

# Optional: first-run demo user (only inserted if username does not exist)
# SEED_USERNAME=demo
# SEED_EMAIL=demo@example.com
# SEED_PASSWORD=demoPass123

# Docker Compose (see docker-compose.yml)
# APP_PORT=5000
# APP_VERSION=dev
# IMAGE_TAG=latest

# Optional — Sentry (app.py enables SDK only when this is set)
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
